{
  "name": "piranhanet",
  "version": "0.0.1-alpha",
  "description": "Applications for running Piranha, providing Electron and web interfaces",
  "main": "./out/main/index.js",
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "build": {
    "appId": "org.polionanopore.piranhanet",
    "productName": "PiranhaNET",
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PiranhaNET"
    }
  },
  "scripts": {
    "format:write": "prettier --plugin prettier-plugin-svelte --write .",
    "format:check": "prettier --plugin prettier-plugin-svelte --check .",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --fix .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "svelte-check": "svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "npm run typecheck:node && npm run svelte-check",
    "start-electron": "electron-vite preview",
    "start-web": "vite preview --config web.vite.config.ts",
    "dev-electron": "electron-vite dev -- --disable-gpu",
    "dev-web": "vite --config web.vite.config.ts",
    "build-electron": "paraglide-js compile --project ./project.inlang --outdir svelte-app/src/paraglide && npm run typecheck && electron-vite build",
    "postinstall-electron": "electron-builder install-app-deps",
    "build-electron:unpack": "npm run build-electron && electron-builder --dir",
    "build-electron:win": "npm run build-electron && electron-builder --win",
    "build-electron:mac": "npm run build-electron && electron-builder --mac",
    "build-electon:linux": "npm run build-electron && electron-builder --linux",
    "build-web": "vite build --config web.vite.config.ts",
    "test:unit": "vitest svelte-app/tests/unit/",
    "test-electron:integration": "vitest piranha-electron/tests/integration/",
    "coverage": "vitest run --coverage",
    "test-electron:e2e": "electron-vite piranha-electron/build && xvfb-run npx playwright test"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "ansi_up": "^6.0.6",
    "throttleit": "^3.0.0",
    "dockerode": "^4.0.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@inlang/paraglide-js": "^2.14.0",
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^1.23.0",
    "@playwright/test": "^1.58.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.1",
    "@vitest/coverage-istanbul": "^4.0.18",
    "ansi-parser": "^3.2.11",
    "bits-ui": "^2.16.3",
    "clsx": "^2.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-svelte": "^3.13.1",
    "formsnap": "^2.0.1",
    "jsdom": "^28.1.0",
    "prettier": "^3.7.4",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.45.6",
    "svelte-check": "^4.3.4",
    "svelte-tiny-router": "^1.0.8",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.0.18"
  }
}
