{
  "$schema": "https://shadcn-svelte.com/schema.json",
  "tailwind": {
    "css": "svelte-app/src/assets/app.css",
    "baseColor": "neutral"
  },
  "aliases": {
    "components": "$lib/shadcn",
    "utils": "$lib/shadcn/utils",
    "ui": "$lib/shadcn/ui",
    "hooks": "$lib/shadcn/hooks",
    "lib": "$lib"
  },
  "typescript": true,
  "registry": "https://shadcn-svelte.com/registry",
  "style": "nova",
  "iconLibrary": "lucide",
  "menuColor": "default",
  "menuAccent": "subtle"
}
