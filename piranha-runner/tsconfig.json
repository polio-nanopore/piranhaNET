{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": false,
    "declarationMap": true,
    "esModuleInterop":  true,
    "moduleResolution": "Node"
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "tests/**/*.ts",
    "vitest.config.ts"
  ]
}
